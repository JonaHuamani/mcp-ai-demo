# 🔑 API Keys y Secretos
# Copia este archivo a .env y rellena con tus valores reales

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Strapi Configuration
STRAPI_APP_KEYS=your-app-keys-here
STRAPI_ADMIN_JWT_SECRET=your-admin-jwt-secret-here
STRAPI_JWT_SECRET=your-jwt-secret-here
STRAPI_TOKEN=your-strapi-api-token-here

# 📝 Instrucciones:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena las variables con tus valores reales
# 3. Para Strapi: Los secretos se pueden generar desde el panel de admin
# 4. Para OpenAI: Obtén tu API key desde https://platform.openai.com/api-keys
